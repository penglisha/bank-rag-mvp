# 复制此文件为 .env，填入真实的 API Key
# cp .env.example .env

# ─── LLM 后端（二选一）──────────────────────────────────
# anthropic（默认）：调用 Anthropic Claude API，需要 ANTHROPIC_API_KEY
# ollama           ：调用本地 Ollama，完全免费，无需任何 API Key
LLM_BACKEND=anthropic

# ─── Anthropic Claude（LLM_BACKEND=anthropic 时需要）─────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# claude-haiku-4-5    ← 速度快、成本低，适合学习实验（默认）
# claude-sonnet-4-6   ← 质量更好
# claude-opus-4-8     ← 质量最高
ANTHROPIC_MODEL=claude-haiku-4-5

# ─── Ollama（LLM_BACKEND=ollama 时需要）──────────────────
# 前置步骤：
#   1. 安装 Ollama: https://ollama.com/download
#   2. 拉取模型:    ollama pull qwen2.5:7b
#   3. 把上面 LLM_BACKEND 改为 ollama
OLLAMA_MODEL=qwen2.5:7b

# ─── Embedding 模式（可选，默认 local）───────────────────
# local  → 使用本地 sentence-transformers，完全免费，支持中文（默认）
# openai → 使用 OpenAI text-embedding-3-small，需付费
EMBEDDING_MODE=local

# ─── OpenAI（仅 EMBEDDING_MODE=openai 时需要）────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ─── RAG 参数（实验用）───────────────────────────────────
# 文本块大小（字符数）
# 调小（如200）→ 检索更精准，但单块信息量少
# 调大（如800）→ 每块信息更完整，但语义可能不聚焦
CHUNK_SIZE=400

# 检索返回的文本块数量
# 调小（如1）→ 速度快，但可能遗漏相关信息
# 调大（如5）→ 上下文更丰富，但 prompt 变长、成本增加
TOP_K=3
